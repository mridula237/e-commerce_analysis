  );

[0m14:48:17.603293 [debug] [Thread-4 (]: On model.thelook_pipeline.stg_products: /* {"app": "dbt", "dbt_version": "1.8.0", "profile_name": "thelook_pipeline", "target_name": "dev", "node_id": "model.thelook_pipeline.stg_products"} */

  
  create view "thelook"."main_staging"."stg_products__dbt_tmp" as (
    -- models/staging/stg_products.sql
WITH source AS (
    SELECT * FROM "thelook"."main"."raw_products"
)

SELECT
    CAST(id AS VARCHAR)                         AS product_id,
    name                                        AS product_name,
    category,
    brand,
    department,
    sku,
    CAST(cost AS DOUBLE)                        AS cost,
    CAST(retail_price AS DOUBLE)                AS retail_price,
    CAST(retail_price - cost AS DOUBLE)         AS gross_margin,
    CASE
        WHEN cost > 0
        THEN ROUND((retail_price - cost) / cost * 100, 2)
        ELSE NULL
    END                                         AS margin_pct,
    CAST(distribution_center_id AS VARCHAR)     AS distribution_center_id
FROM source
WHERE id IS NOT NULL
  AND retail_price > 0
  );

