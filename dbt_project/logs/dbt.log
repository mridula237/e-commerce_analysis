  create view "thelook"."main_staging"."stg_events__dbt_tmp" as (
    -- models/staging/stg_events.sql
WITH source AS (
    SELECT * FROM "thelook"."main"."raw_events"
)

SELECT
    CAST(id AS VARCHAR)                              AS event_id,
    CAST(user_id AS VARCHAR)                         AS user_id,
    sequence_number,
    session_id,
    CAST(created_at AS TIMESTAMP)                    AS event_at,
    DATE_TRUNC('day', CAST(created_at AS TIMESTAMP)) AS event_date,
    ip_address,
    city,
    state,
    postal_code                                      AS zip,
    browser,
    traffic_source,
    uri,
    event_type
FROM source
WHERE id IS NOT NULL
  AND event_type IN ('home', 'category', 'brand', 'product',
                     'cart', 'purchase', 'cancel')
  );

