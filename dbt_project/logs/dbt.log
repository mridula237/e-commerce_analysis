  create or replace view `thelook-pipeline`.`staging`.`stg_order_items`
  OPTIONS()
  as -- models/staging/stg_order_items.sql
WITH source AS (
    SELECT * FROM `thelook-pipeline`.`raw`.`raw_order_items`
)

SELECT
    CAST(id AS VARCHAR)                         AS order_item_id,
    CAST(order_id AS VARCHAR)                   AS order_id,
    CAST(user_id AS VARCHAR)                    AS user_id,
    CAST(product_id AS VARCHAR)                 AS product_id,
    CAST(inventory_item_id AS VARCHAR)          AS inventory_item_id,
    status                                      AS item_status,
    CAST(created_at AS TIMESTAMP)               AS created_at,
    CAST(shipped_at AS TIMESTAMP)               AS shipped_at,
    CAST(delivered_at AS TIMESTAMP)             AS delivered_at,
    CAST(returned_at AS TIMESTAMP)              AS returned_at,
    CAST(sale_price AS DOUBLE)                  AS sale_price,
    CASE WHEN status = 'Returned' OR returned_at IS NOT NULL
         THEN TRUE ELSE FALSE END               AS is_returned
FROM source
WHERE order_id IS NOT NULL;


[0m10:09:40.418659 [debug] [Thread-4 (]: On model.thelook_pipeline.stg_products: /* {"app": "dbt", "dbt_version": "1.8.0", "profile_name": "thelook_pipeline", "target_name": "dev", "node_id": "model.thelook_pipeline.stg_products"} */


  create or replace view `thelook-pipeline`.`staging`.`stg_products`
  OPTIONS()
  as -- models/staging/stg_products.sql
WITH source AS (
    SELECT * FROM `thelook-pipeline`.`raw`.`raw_products`
)

SELECT
    CAST(id AS VARCHAR)                         AS product_id,
    name                                        AS product_name,
    category,
    brand,
    department,
    sku,
    CAST(cost AS DOUBLE)                        AS cost,
    CAST(retail_price AS DOUBLE)                AS retail_price,
    CAST(retail_price - cost AS DOUBLE)         AS gross_margin,
    CASE
        WHEN cost > 0
        THEN ROUND((retail_price - cost) / cost * 100, 2)
        ELSE NULL
    END                                         AS margin_pct,
    CAST(distribution_center_id AS VARCHAR)     AS distribution_center_id
FROM source
WHERE id IS NOT NULL
  AND retail_price > 0;


